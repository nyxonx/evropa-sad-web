---
import Header from '../components/layout/Header.astro';
import Footer from '../components/footer/Footer.astro';
import { defaultLang, languages, type Lang } from '../i18n/config';
import { localizePath, removeLangPrefix } from '../i18n/routing';
import { translations } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  lang?: Lang;
}

const {
  lang = defaultLang,
  title = translations[lang].site.defaultTitle,
  description = translations[lang].site.defaultDescription,
  canonical,
  image = '/favicon.svg',
  noindex = false,
} = Astro.props;

const siteTitle = translations[lang].site.defaultTitle;
const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonicalUrl = canonical ?? Astro.url.href;
const pathWithoutLocale = removeLangPrefix(Astro.url.pathname);
const alternateUrls = Object.entries(languages).map(([locale, language]) => ({
  locale,
  htmlLang: language.htmlLang,
  href: new URL(localizePath(locale as Lang, pathWithoutLocale), Astro.url.origin).href,
}));
---

<!doctype html>
<html lang={languages[lang].htmlLang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateUrls.map((alternate) => (
        <link rel="alternate" hreflang={alternate.htmlLang} href={alternate.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath(defaultLang, pathWithoutLocale), Astro.url.origin).href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-950 antialiased">
    <Header lang={lang} />
    <main id="main-content" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
