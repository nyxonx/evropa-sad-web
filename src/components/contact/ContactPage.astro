---
import type { Lang } from '../../i18n/config';
import { translations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const footerContact = translations[lang].footer.contactItems;

const copy = {
  sr: {
    heroKicker: 'KONTAKT',
    heroTitle: 'Otvoreni za pitanja, inicijative i saradnju',
    heroLead:
      'Pišite nam, posjetite kancelariju ili se obratite timu Pokreta Evropa sad za informacije o članstvu, lokalnim odborima, medijima i programskim inicijativama.',
    navLabel: 'Kontakt navigacija',
    nav: [
      { href: '#poruka', label: 'Pošalji poruku' },
      { href: '#kancelarija', label: 'Kancelarija' },
      { href: '#mreze', label: 'Društvene mreže' },
    ],
    formKicker: 'POŠALJI PORUKU',
    formTitle: 'Kako možemo da pomognemo?',
    formText:
      'Forma za sada otvara email klijent sa pripremljenom porukom. Kada uvedemo backend integraciju, slanje će ići direktno kroz sajt.',
    nameLabel: 'Ime i prezime',
    emailLabel: 'Email',
    topicLabel: 'Tema',
    messageLabel: 'Poruka',
    submitLabel: 'Pošalji email',
    topicPlaceholder: 'Članstvo, lokalni odbor, mediji...',
    messagePlaceholder: 'Napišite kratko šta vam je potrebno.',
    officeKicker: 'KANCELARIJA',
    officeTitle: 'Mjesto za direktan kontakt',
    officeText:
      'Za informacije o radu Pokreta, dokumentima, lokalnim odborima i javnim aktivnostima možete nas kontaktirati emailom, telefonom ili posjetom kancelariji.',
    contactCards: [
      { title: 'Adresa', hint: 'Kancelarija Pokreta', icon: 'location' },
      { title: 'Email', hint: 'Za opšta pitanja', icon: 'mail' },
      { title: 'Telefon', hint: 'Radnim danima', icon: 'phone' },
    ],
    mapCta: 'Otvori mapu',
    socialsKicker: 'ONLINE',
    socialsTitle: 'Pratite aktivnosti Pokreta',
    socialsText: 'Društvene mreže koristimo za aktuelne informacije, javne poruke i aktivnosti sa terena.',
    requiredNote: 'Sva polja su potrebna za pripremu email poruke.',
  },
  en: {
    heroKicker: 'CONTACT',
    heroTitle: 'Open for questions, initiatives and cooperation',
    heroLead:
      'Write to us, visit the office or contact the Europe Now Movement team for information about membership, local boards, media and program initiatives.',
    navLabel: 'Contact navigation',
    nav: [
      { href: '#poruka', label: 'Send message' },
      { href: '#kancelarija', label: 'Office' },
      { href: '#mreze', label: 'Social media' },
    ],
    formKicker: 'SEND A MESSAGE',
    formTitle: 'How can we help?',
    formText:
      'For now, the form opens your email client with a prepared message. Once backend integration is added, sending will work directly through the website.',
    nameLabel: 'Full name',
    emailLabel: 'Email',
    topicLabel: 'Topic',
    messageLabel: 'Message',
    submitLabel: 'Send email',
    topicPlaceholder: 'Membership, local board, media...',
    messagePlaceholder: 'Briefly write what you need.',
    officeKicker: 'OFFICE',
    officeTitle: 'A place for direct contact',
    officeText:
      'For information about Movement work, documents, local boards and public activities, you can contact us by email, phone or by visiting the office.',
    contactCards: [
      { title: 'Address', hint: 'Movement office', icon: 'location' },
      { title: 'Email', hint: 'For general questions', icon: 'mail' },
      { title: 'Phone', hint: 'On working days', icon: 'phone' },
    ],
    mapCta: 'Open map',
    socialsKicker: 'ONLINE',
    socialsTitle: 'Follow Movement activities',
    socialsText: 'We use social media for updates, public messages and field activities.',
    requiredNote: 'All fields are needed to prepare the email message.',
  },
} as const;

const t = copy[lang];
const emailAddress = footerContact.find((item) => item.href.startsWith('mailto:'))?.label ?? 'info@evropasad.com';
const addressItem = footerContact.find((item) => item.href.startsWith('https://maps.google.com'));
const contactIcons: Record<string, string> = {
  location: 'M12 21s7-4.7 7-11a7 7 0 1 0-14 0c0 6.3 7 11 7 11Zm0-8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  mail: 'M4 6h16v12H4zM4 7l8 6 8-6',
  phone: 'M6.5 4h3l1.5 4-2 1.2a12 12 0 0 0 5.8 5.8L16 13l4 1.5v3a2 2 0 0 1-2.2 2 16 16 0 0 1-13.3-13.3A2 2 0 0 1 6.5 4Z',
};

const socialLinks = [
  {
    href: 'https://www.facebook.com/',
    label: 'Facebook',
    icon: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3.5l.5-4h-4V7a1 1 0 0 1 1-1h3V2Z',
  },
  {
    href: 'https://www.instagram.com/',
    label: 'Instagram',
    icon: 'M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm5 5.2A4.8 4.8 0 1 0 12 16.8 4.8 4.8 0 0 0 12 7.2Zm6.2-.2h.01',
  },
  {
    href: 'https://www.youtube.com/',
    label: 'YouTube',
    icon: 'M21.6 7.2a2.8 2.8 0 0 0-2-2C17.8 4.8 12 4.8 12 4.8s-5.8 0-7.6.4a2.8 2.8 0 0 0-2 2A29.4 29.4 0 0 0 2 12a29.4 29.4 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.4 7.6.4 7.6.4s5.8 0 7.6-.4a2.8 2.8 0 0 0 2-2A29.4 29.4 0 0 0 22 12a29.4 29.4 0 0 0-.4-4.8ZM10 15V9l5.2 3L10 15Z',
  },
  {
    href: 'https://www.tiktok.com/',
    label: 'TikTok',
    icon: 'M15 3c.4 2.6 1.9 4.1 4 4.4V11a7.4 7.4 0 0 1-4-1.2v5.4a5.8 5.8 0 1 1-5.8-5.8c.4 0 .8 0 1.2.1v3.8a2.2 2.2 0 1 0 1.6 2.1V3h3Z',
  },
];
---

<section class="relative isolate overflow-hidden bg-[#061632] pb-20 pt-32 text-white sm:pt-36 lg:pt-40">
  <img src="/images/homepage-hero-clean.png" alt="" class="absolute inset-0 -z-30 h-full w-full object-cover opacity-24" loading="eager" />
  <div class="absolute inset-0 -z-20 bg-[linear-gradient(110deg,rgba(6,22,50,0.98)_0%,rgba(8,43,99,0.92)_48%,rgba(6,22,50,0.78)_100%)]"></div>
  <div class="absolute left-1/2 top-24 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-[#d6ad3b]/18 blur-3xl"></div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-t from-slate-50 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#f0cf72]">{t.heroKicker}</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-bold tracking-normal sm:text-5xl lg:text-6xl">{t.heroTitle}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-blue-50/88">{t.heroLead}</p>
    </div>
  </div>
</section>

<nav class="relative z-20 mx-auto -mt-7 max-w-7xl px-4 sm:px-6 lg:px-8" aria-label={t.navLabel}>
  <div class="grid gap-2 rounded-lg border border-slate-200 bg-white p-2 shadow-xl shadow-slate-300/50 sm:grid-cols-3">
    {
      t.nav.map((item, index) => (
        <a
          href={item.href}
          class:list={[
            'flex min-h-12 items-center justify-center rounded-md px-3 py-2 text-center text-xs font-bold uppercase tracking-[0.12em] transition focus:outline-none focus:ring-2 focus:ring-[#d6ad3b]',
            index === 0 ? 'bg-[#fff8e3] text-[#8a6a13] ring-1 ring-[#d6ad3b]/55' : 'text-[#082b63] hover:bg-[#eef4ff]',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</nav>

<section id="poruka" class="scroll-mt-24 bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.88fr_1.12fr] lg:px-8">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.formKicker}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">{t.formTitle}</h2>
      <p class="mt-4 text-base leading-8 text-slate-700">{t.formText}</p>

      <div class="mt-8 grid gap-4">
        {
          t.contactCards.map((card, index) => {
            const contact = footerContact[index];
            return (
              <a
                href={contact.href}
                class="group rounded-lg border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/80 transition hover:-translate-y-1 hover:border-[#d6ad3b]/70 hover:shadow-xl hover:shadow-slate-300/70 focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
              >
                <span class="flex items-start gap-4">
                  <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-md bg-[#fff8e3] text-[#b48924] transition group-hover:bg-[#d6ad3b] group-hover:text-[#061632]">
                    <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 fill-none stroke-current stroke-[1.8]">
                      <path d={contactIcons[card.icon]} stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <span>
                    <span class="block text-xs font-bold uppercase tracking-[0.16em] text-[#b48924]">{card.hint}</span>
                    <span class="mt-1 block text-lg font-bold text-[#061632]">{card.title}</span>
                    <span class="mt-2 block text-sm leading-6 text-slate-600">{contact.label}</span>
                  </span>
                </span>
              </a>
            );
          })
        }
      </div>
    </div>

    <form
      class="rounded-2xl border border-slate-200 bg-white p-5 shadow-xl shadow-slate-200/80 sm:p-7"
      data-contact-form
      data-contact-email={emailAddress}
    >
      <p class="text-sm leading-7 text-slate-600">{t.requiredNote}</p>

      <div class="mt-6 grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#082b63]">{t.nameLabel}</span>
          <input
            name="name"
            required
            class="mt-2 min-h-12 w-full rounded-md border border-slate-200 bg-slate-50 px-4 text-sm text-[#061632] outline-none transition focus:border-[#d6ad3b] focus:bg-white focus:ring-2 focus:ring-[#d6ad3b]/40"
          />
        </label>

        <label class="block">
          <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#082b63]">{t.emailLabel}</span>
          <input
            name="email"
            type="email"
            required
            class="mt-2 min-h-12 w-full rounded-md border border-slate-200 bg-slate-50 px-4 text-sm text-[#061632] outline-none transition focus:border-[#d6ad3b] focus:bg-white focus:ring-2 focus:ring-[#d6ad3b]/40"
          />
        </label>
      </div>

      <label class="mt-5 block">
        <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#082b63]">{t.topicLabel}</span>
        <input
          name="topic"
          required
          placeholder={t.topicPlaceholder}
          class="mt-2 min-h-12 w-full rounded-md border border-slate-200 bg-slate-50 px-4 text-sm text-[#061632] outline-none transition placeholder:text-slate-400 focus:border-[#d6ad3b] focus:bg-white focus:ring-2 focus:ring-[#d6ad3b]/40"
        />
      </label>

      <label class="mt-5 block">
        <span class="text-xs font-bold uppercase tracking-[0.16em] text-[#082b63]">{t.messageLabel}</span>
        <textarea
          name="message"
          required
          rows="7"
          placeholder={t.messagePlaceholder}
          class="mt-2 w-full resize-y rounded-md border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-7 text-[#061632] outline-none transition placeholder:text-slate-400 focus:border-[#d6ad3b] focus:bg-white focus:ring-2 focus:ring-[#d6ad3b]/40"
        ></textarea>
      </label>

      <button
        type="submit"
        class="mt-6 inline-flex min-h-12 items-center justify-center gap-4 rounded-md bg-[#061632] px-6 text-sm font-bold uppercase text-white shadow-lg shadow-slate-300/80 transition hover:-translate-y-0.5 hover:bg-[#082b63] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
      >
        {t.submitLabel}
        <span aria-hidden="true" class="text-xl leading-none">→</span>
      </button>
    </form>
  </div>
</section>

<section id="kancelarija" class="scroll-mt-24 bg-white py-16 sm:py-20">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:px-8">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.officeKicker}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">{t.officeTitle}</h2>
      <p class="mt-4 text-base leading-8 text-slate-700">{t.officeText}</p>

      {
        addressItem && (
          <a
            href={addressItem.href}
            class="mt-7 inline-flex min-h-12 items-center justify-center gap-4 rounded-md border border-[#082b63]/25 bg-white px-6 text-sm font-bold uppercase text-[#082b63] shadow-sm shadow-slate-200 transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#fff8e3] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
          >
            {t.mapCta}
            <span aria-hidden="true" class="text-xl leading-none">→</span>
          </a>
        )
      }
    </div>

    <div class="relative isolate overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-xl shadow-slate-200/80 sm:p-8">
      <div aria-hidden="true" class="absolute -right-20 -top-24 -z-10 h-64 w-64 rounded-full bg-[#d6ad3b]/16 blur-3xl"></div>
      <div aria-hidden="true" class="absolute -bottom-24 left-2 -z-10 h-64 w-64 rounded-full bg-[#082b63]/10 blur-3xl"></div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.officeKicker}</p>
        <p class="mt-3 text-2xl font-bold text-[#061632]">{addressItem?.label ?? footerContact[0]?.label}</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {
            footerContact.slice(1).map((item) => (
              <a href={item.href} class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm font-bold text-[#082b63] transition hover:border-[#d6ad3b] hover:bg-[#fff8e3] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2">
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<section id="mreze" class="scroll-mt-24 bg-slate-50 pb-16 sm:pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-xl shadow-slate-200/80 sm:p-8">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.socialsKicker}</p>
          <h2 class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">{t.socialsTitle}</h2>
          <p class="mt-4 text-base leading-8 text-slate-700">{t.socialsText}</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                class="group flex min-h-28 flex-col justify-between rounded-xl border border-slate-200 bg-slate-50 p-4 transition hover:-translate-y-1 hover:border-[#d6ad3b]/70 hover:bg-[#fff8e3] hover:shadow-lg hover:shadow-slate-200/80 focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
                aria-label={link.label}
              >
                <span class="flex h-11 w-11 items-center justify-center rounded-md bg-[#061632] text-white transition group-hover:bg-[#d6ad3b] group-hover:text-[#061632]">
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
                    <path d={link.icon} stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span class="mt-4 text-sm font-bold uppercase tracking-[0.12em] text-[#082b63]">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const initContactForm = () => {
    const form = document.querySelector('[data-contact-form]');
    if (!form || form.dataset.contactInitialized === 'true') {
      return;
    }

    form.dataset.contactInitialized = 'true';

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const data = new FormData(form);
      const email = form.getAttribute('data-contact-email') || 'info@evropasad.com';
      const name = String(data.get('name') || '').trim();
      const sender = String(data.get('email') || '').trim();
      const topic = String(data.get('topic') || '').trim();
      const message = String(data.get('message') || '').trim();

      if (!name || !sender || !topic || !message) {
        form.reportValidity();
        return;
      }

      const body = [`Ime i prezime: ${name}`, `Email: ${sender}`, '', message].join('\n');
      const href = `mailto:${email}?subject=${encodeURIComponent(topic)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    });
  };

  document.addEventListener('astro:page-load', initContactForm);
  initContactForm();
</script>
