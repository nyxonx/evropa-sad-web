---
import type { Lang } from '../../i18n/config';
import { getNews } from '../../data';
import CTASection from '../sections/CTASection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const newsItems = getNews(lang);

const copy = {
  sr: {
    heroKicker: 'VIJESTI',
    heroTitle: 'Aktuelnosti, aktivnosti i poruke Pokreta',
    heroLead:
      'Pregled najvažnijih vijesti, terenskih aktivnosti, javnih nastupa i institucionalnih tema Pokreta Evropa sad.',
    filtersLabel: 'Filter vijesti',
    filters: {
      all: 'Sve vijesti',
      economy: 'Ekonomija',
      organization: 'Organizacija',
      tourism: 'Crna Gora',
    },
    listKicker: 'AKTUELNO',
    listTitle: 'Vijesti po oblastima',
    listText: 'Filtriraj objave po temi i otvori detalje za kratak pregled sadržaja bez napuštanja stranice.',
    detailsCta: 'Detalji',
    closePanel: 'Zatvori',
    panelLabel: 'Detalji vijesti',
    publishedLabel: 'Objavljeno',
    categoryLabel: 'Oblast',
    summaryLabel: 'Sažetak',
    contentLabel: 'Sadržaj',
    noNews: 'Nema vijesti za izabrani filter.',
  },
  en: {
    heroKicker: 'NEWS',
    heroTitle: 'Updates, activities and Movement messages',
    heroLead:
      'A review of the most important news, field activities, public appearances and institutional topics of the Europe Now Movement.',
    filtersLabel: 'News filter',
    filters: {
      all: 'All news',
      economy: 'Economy',
      organization: 'Organization',
      tourism: 'Montenegro',
    },
    listKicker: 'LATEST',
    listTitle: 'News by area',
    listText: 'Filter posts by topic and open details for a short content overview without leaving the page.',
    detailsCta: 'Details',
    closePanel: 'Close',
    panelLabel: 'News details',
    publishedLabel: 'Published',
    categoryLabel: 'Area',
    summaryLabel: 'Summary',
    contentLabel: 'Content',
    noNews: 'No news for the selected filter.',
  },
} as const;

const t = copy[lang];

const categoryOrder = ['economy', 'organization', 'tourism'];
const categories = [
  { id: 'all', label: t.filters.all },
  ...categoryOrder
    .filter((category) => newsItems.some((item) => item.category === category))
    .map((category) => ({
      id: category,
      label: t.filters[category as keyof typeof t.filters] ?? category,
    })),
];

const newsJson = JSON.stringify(newsItems);

const toneClasses: Record<string, string> = {
  eu: 'bg-[radial-gradient(circle_at_68%_34%,rgba(214,173,59,0.72),transparent_15%),linear-gradient(135deg,#082b63_0%,#0b3f91_48%,#061632_100%)]',
  team: 'bg-[radial-gradient(circle_at_28%_28%,rgba(255,255,255,0.42),transparent_16%),linear-gradient(135deg,#9ca3af_0%,#334155_48%,#0f172a_100%)]',
  coast: 'bg-[radial-gradient(circle_at_78%_22%,rgba(255,255,255,0.66),transparent_14%),linear-gradient(135deg,#38bdf8_0%,#0b4ea5_42%,#075985_100%)]',
};

const getToneClass = (tone: string) => toneClasses[tone] ?? toneClasses.eu;
const getCategoryLabel = (category: string) => t.filters[category as keyof typeof t.filters] ?? category;
---

<section class="relative isolate overflow-hidden bg-[#061632] pb-20 pt-32 text-white sm:pt-36 lg:pt-40">
  <img src="/images/homepage-hero-clean.png" alt="" class="absolute inset-0 -z-30 h-full w-full object-cover opacity-24" loading="eager" />
  <div class="absolute inset-0 -z-20 bg-[linear-gradient(110deg,rgba(6,22,50,0.98)_0%,rgba(8,43,99,0.92)_48%,rgba(6,22,50,0.78)_100%)]"></div>
  <div class="absolute left-1/2 top-24 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-[#d6ad3b]/18 blur-3xl"></div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-t from-slate-50 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#f0cf72]">{t.heroKicker}</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-bold tracking-normal sm:text-5xl lg:text-6xl">{t.heroTitle}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-blue-50/88">{t.heroLead}</p>
    </div>
  </div>
</section>

<nav class="relative z-20 mx-auto -mt-7 max-w-7xl px-4 sm:px-6 lg:px-8" aria-label={t.filtersLabel} data-news-page>
  <div class="grid gap-2 rounded-lg border border-slate-200 bg-white p-2 shadow-xl shadow-slate-300/50 sm:grid-cols-2 lg:grid-cols-4" role="group" aria-label={t.filtersLabel}>
    {
      categories.map((category, index) => (
        <button
          type="button"
          class:list={[
            'flex min-h-12 items-center justify-center rounded-md px-3 py-2 text-center text-xs font-bold uppercase tracking-[0.12em] transition focus:outline-none focus:ring-2 focus:ring-[#d6ad3b]',
            index === 0 ? 'bg-[#fff8e3] text-[#8a6a13] ring-1 ring-[#d6ad3b]/55' : 'text-[#082b63] hover:bg-[#eef4ff]',
          ]}
          data-news-filter={category.id}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {category.label}
        </button>
      ))
    }
  </div>
</nav>

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.listKicker}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">{t.listTitle}</h2>
      <p class="mt-4 text-base leading-8 text-slate-700">{t.listText}</p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        newsItems.map((item) => (
          <article
            class="group flex min-h-full flex-col overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm shadow-slate-200/80 transition duration-300 hover:-translate-y-1 hover:border-[#d6ad3b]/70 hover:shadow-xl hover:shadow-slate-300/70"
            data-news-card
            data-category={item.category}
          >
            <div class:list={['relative min-h-56 overflow-hidden', item.imageSrc ? 'bg-slate-200' : getToneClass(item.tone)]}>
              {
                item.imageSrc && (
                  <img
                    src={item.imageSrc}
                    alt=""
                    class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                )
              }
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,22,50,0.02)_0%,rgba(6,22,50,0.62)_100%)]"></div>
              <time datetime={item.date} class="absolute left-4 top-4 flex h-14 w-14 flex-col items-center justify-center rounded-md border border-[#d6ad3b]/70 bg-[#082b63] text-white shadow-lg shadow-black/20">
                <span class="text-xl font-bold leading-none">{item.day}</span>
                <span class="mt-1 text-[0.62rem] font-bold uppercase tracking-[0.12em] text-[#d6ad3b]">{item.month}</span>
              </time>
              <div class="absolute bottom-4 left-4 rounded-sm bg-white/92 px-2.5 py-1 text-[0.65rem] font-bold uppercase tracking-[0.14em] text-[#082b63] shadow-sm">
                {getCategoryLabel(item.category)}
              </div>
            </div>

            <div class="flex flex-1 flex-col p-5">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-[#b48924]">{item.categoryLabel}</p>
              <h3 class="mt-3 text-xl font-bold leading-snug text-[#061632]">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.excerpt}</p>

              <button
                type="button"
                class="mt-6 inline-flex min-h-11 w-fit items-center justify-center gap-3 rounded-md border border-[#082b63]/20 bg-[#061632] px-4 text-xs font-bold uppercase text-white shadow-lg shadow-slate-200/80 transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#082b63] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
                data-news-open={item.slug}
                aria-expanded="false"
                aria-controls="news-detail-panel"
                aria-label={`${item.title}: ${t.detailsCta}`}
              >
                {t.detailsCta}
                <span aria-hidden="true" class="flex h-6 w-6 items-center justify-center rounded-full bg-[#d6ad3b] text-base leading-none text-[#061632]">+</span>
              </button>
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-8 hidden rounded-lg border border-slate-200 bg-white p-5 text-sm leading-6 text-slate-600 shadow-sm shadow-slate-200/80" data-news-empty>
      {t.noNews}
    </p>
  </div>
</section>

<div id="news-detail-modal" class="fixed inset-0 z-[80] hidden" aria-hidden="true">
  <button type="button" class="absolute inset-0 bg-[#061632]/72 opacity-0 transition-opacity duration-300 lg:pointer-events-none" data-news-overlay aria-label={t.closePanel}></button>
  <aside
    id="news-detail-panel"
    class="absolute inset-x-0 bottom-0 max-h-[92vh] translate-y-full overflow-y-auto rounded-t-2xl border border-white/15 bg-white shadow-2xl shadow-black/30 transition duration-300 lg:inset-y-0 lg:left-auto lg:right-0 lg:h-full lg:max-h-none lg:w-full lg:max-w-xl lg:translate-x-full lg:translate-y-0 lg:rounded-l-2xl lg:rounded-tr-none"
    role="dialog"
    aria-modal="true"
    aria-labelledby="news-detail-title"
    aria-label={t.panelLabel}
    tabindex="-1"
  >
    <div class="relative isolate overflow-hidden bg-[#061632] px-5 py-6 text-white sm:px-7">
      <div class="absolute right-8 top-8 -z-10 h-32 w-32 rounded-full bg-[#d6ad3b]/20 blur-3xl"></div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#f0cf72]" data-news-category></p>
          <h2 id="news-detail-title" class="mt-3 text-3xl font-bold tracking-normal" data-news-title></h2>
        </div>
        <button
          type="button"
          class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-white/20 bg-white/10 text-white transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-white/15 focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2 focus:ring-offset-[#061632]"
          data-news-close
          aria-label={t.closePanel}
        >
          <span aria-hidden="true" class="text-2xl leading-none">&times;</span>
        </button>
      </div>
      <p class="mt-5 text-sm leading-7 text-blue-50/88" data-news-excerpt></p>
    </div>

    <div class="space-y-7 px-5 py-6 sm:px-7">
      <div class="grid gap-3 sm:grid-cols-2">
        <article class="rounded-lg border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-xs font-bold uppercase tracking-[0.16em] text-[#b48924]">{t.publishedLabel}</h3>
          <p class="mt-2 text-sm font-bold text-[#061632]" data-news-date></p>
        </article>
        <article class="rounded-lg border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-xs font-bold uppercase tracking-[0.16em] text-[#b48924]">{t.categoryLabel}</h3>
          <p class="mt-2 text-sm font-bold text-[#061632]" data-news-category-label></p>
        </article>
      </div>

      <section aria-labelledby="news-summary-heading">
        <h3 id="news-summary-heading" class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.summaryLabel}</h3>
        <p class="mt-2 text-sm leading-7 text-slate-700" data-news-summary></p>
      </section>

      <section aria-labelledby="news-content-heading">
        <h3 id="news-content-heading" class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.contentLabel}</h3>
        <div class="mt-3 space-y-4" data-news-body></div>
      </section>

      <button
        type="button"
        class="inline-flex min-h-11 items-center justify-center rounded-md bg-[#061632] px-5 text-xs font-bold uppercase text-white transition hover:-translate-y-0.5 hover:bg-[#082b63] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
        data-news-close
      >
        {t.closePanel}
      </button>
    </div>
  </aside>
</div>

<script id="news-detail-data" type="application/json" set:html={newsJson}></script>
<script id="news-copy-data" type="application/json" set:html={JSON.stringify({ categories: t.filters })}></script>

<CTASection lang={lang} />

<script>
  const initNewsPage = () => {
    const root = document.querySelector('[data-news-page]');
    if (!root || root.dataset.newsInitialized === 'true') {
      return;
    }

    root.dataset.newsInitialized = 'true';

    const newsDataScript = document.getElementById('news-detail-data');
    const copyDataScript = document.getElementById('news-copy-data');
    const modal = document.getElementById('news-detail-modal');
    const panel = document.getElementById('news-detail-panel');
    const overlay = document.querySelector('[data-news-overlay]');
    const filterButtons = Array.from(document.querySelectorAll('[data-news-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-news-card]'));
    const openButtons = Array.from(document.querySelectorAll('[data-news-open]'));
    const closeButtons = Array.from(document.querySelectorAll('[data-news-close]'));
    const emptyState = document.querySelector('[data-news-empty]');

    if (!newsDataScript || !copyDataScript || !modal || !panel || !overlay) {
      return;
    }

    const newsItems = JSON.parse(newsDataScript.textContent || '[]');
    const newsBySlug = new Map(newsItems.map((item) => [item.slug, item]));
    const copy = JSON.parse(copyDataScript.textContent || '{}');
    const fields = {
      category: panel.querySelector('[data-news-category]'),
      title: panel.querySelector('[data-news-title]'),
      excerpt: panel.querySelector('[data-news-excerpt]'),
      date: panel.querySelector('[data-news-date]'),
      categoryLabel: panel.querySelector('[data-news-category-label]'),
      summary: panel.querySelector('[data-news-summary]'),
      body: panel.querySelector('[data-news-body]'),
    };
    const focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';
    let activeTrigger = null;
    let closeTimer = null;
    let previousBodyOverflow = '';

    const setText = (element, text) => {
      if (element) {
        element.textContent = text || '';
      }
    };

    const applyFilter = (filter) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const shouldShow = filter === 'all' || card.getAttribute('data-category') === filter;
        card.classList.toggle('hidden', !shouldShow);
        if (shouldShow) {
          visibleCount += 1;
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }

      filterButtons.forEach((button) => {
        const isActive = button.getAttribute('data-news-filter') === filter;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('bg-[#fff8e3]', isActive);
        button.classList.toggle('text-[#8a6a13]', isActive);
        button.classList.toggle('ring-1', isActive);
        button.classList.toggle('ring-[#d6ad3b]/55', isActive);
        button.classList.toggle('text-[#082b63]', !isActive);
        button.classList.toggle('hover:bg-[#eef4ff]', !isActive);
      });
    };

    const renderBody = (paragraphs) => {
      if (!fields.body) {
        return;
      }

      fields.body.innerHTML = '';
      paragraphs.forEach((paragraph) => {
        const item = document.createElement('p');
        item.className = 'text-sm leading-7 text-slate-700';
        item.textContent = paragraph;
        fields.body.append(item);
      });
    };

    const unlockBodyScroll = () => {
      document.body.style.overflow = previousBodyOverflow;
    };

    const closePanel = () => {
      clearTimeout(closeTimer);
      modal.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0');
      panel.classList.remove('translate-y-0', 'lg:translate-x-0');
      panel.classList.add('translate-y-full', 'lg:translate-x-full');

      openButtons.forEach((button) => button.setAttribute('aria-expanded', 'false'));

      closeTimer = window.setTimeout(() => {
        modal.classList.add('hidden');
        unlockBodyScroll();
        if (activeTrigger) {
          activeTrigger.focus();
        }
        activeTrigger = null;
      }, 300);
    };

    const openPanel = (slug, trigger) => {
      const item = newsBySlug.get(slug);
      if (!item) {
        return;
      }

      clearTimeout(closeTimer);
      activeTrigger = trigger;
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';

      setText(fields.category, copy.categories?.[item.category] || item.categoryLabel);
      setText(fields.title, item.title);
      setText(fields.excerpt, item.excerpt);
      setText(fields.date, `${item.day}. ${item.month} ${item.date.slice(0, 4)}.`);
      setText(fields.categoryLabel, item.categoryLabel);
      setText(fields.summary, item.excerpt);
      renderBody(item.body || []);

      openButtons.forEach((button) => {
        const isActive = button === trigger;
        button.setAttribute('aria-expanded', String(isActive));
      });

      modal.classList.remove('hidden');
      requestAnimationFrame(() => {
        modal.setAttribute('aria-hidden', 'false');
        overlay.classList.remove('opacity-0');
        overlay.classList.add('opacity-100');
        panel.classList.remove('translate-y-full', 'lg:translate-x-full');
        panel.classList.add('translate-y-0', 'lg:translate-x-0');
        const firstControl = panel.querySelector('[data-news-close]');
        if (firstControl) {
          firstControl.focus();
        }
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFilter(button.getAttribute('data-news-filter') || 'all');
      });
    });

    openButtons.forEach((button) => {
      button.addEventListener('click', () => {
        openPanel(button.getAttribute('data-news-open'), button);
      });
    });

    closeButtons.forEach((button) => button.addEventListener('click', closePanel));
    overlay.addEventListener('click', closePanel);

    document.addEventListener('keydown', (event) => {
      if (modal.getAttribute('aria-hidden') === 'true') {
        return;
      }

      if (event.key === 'Escape') {
        closePanel();
        return;
      }

      if (event.key !== 'Tab') {
        return;
      }

      const focusable = Array.from(panel.querySelectorAll(focusableSelector)).filter((element) => !element.hasAttribute('disabled'));
      if (focusable.length === 0) {
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  };

  document.addEventListener('astro:page-load', initNewsPage);
  initNewsPage();
</script>
