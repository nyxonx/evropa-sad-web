---
import { type Lang } from '../../i18n/config';
import { localizePath } from '../../i18n/routing';
import { translations } from '../../i18n/translations';
import NewsCard from './NewsCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang].news;
---

<section class="bg-slate-50 py-16 sm:py-20" aria-labelledby="news-preview-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.label}</p>
      <h2 id="news-preview-heading" class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">
        {t.title}
      </h2>
      <div class="mx-auto mt-5 h-0.5 w-16 bg-[#d6ad3b]"></div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        t.items.map((item) => (
          <NewsCard
            title={item.title}
            excerpt={item.excerpt}
            href={localizePath(lang, item.href)}
            day={item.day}
            month={item.month}
            tone={item.tone}
            imageSrc={item.imageSrc}
            readMore={t.readMore}
            visualLabel={t.visualLabels[item.tone]}
          />
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href={localizePath(lang, t.allCta.href)}
        class="inline-flex min-h-11 items-center justify-center gap-4 rounded-md border border-[#082b63]/35 bg-white px-6 text-xs font-bold uppercase text-[#082b63] shadow-sm shadow-slate-200 transition duration-300 hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#fff8e3] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
      >
        {t.allCta.label}
        <span aria-hidden="true" class="text-lg leading-none">→</span>
      </a>
    </div>
  </div>
</section>
