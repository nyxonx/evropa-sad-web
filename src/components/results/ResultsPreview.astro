---
import { type Lang } from '../../i18n/config';
import { localizePath } from '../../i18n/routing';
import { translations } from '../../i18n/translations';
import ResultCard from './ResultCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang].results;
---

<section class="bg-slate-50 py-16 sm:py-20" aria-labelledby="results-preview-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.label}</p>
      <h2 id="results-preview-heading" class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">
        {t.title}
      </h2>
      <div class="mx-auto mt-5 h-0.5 w-16 bg-[#d6ad3b]"></div>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-[0.85fr_2.6fr] lg:items-center">
      <div class="max-w-xl lg:max-w-none">
        <p class="text-base leading-8 text-slate-700">{t.text}</p>

        <a
          href={localizePath(lang, t.cta.href)}
          class="mt-8 inline-flex min-h-12 items-center justify-center gap-4 rounded-md bg-[#082b63] px-6 text-sm font-bold uppercase text-white shadow-lg shadow-slate-300/80 transition duration-300 hover:-translate-y-0.5 hover:bg-[#0c3c86] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
        >
          {t.cta.label}
          <span aria-hidden="true" class="text-xl leading-none">→</span>
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          t.cards.map((result) => (
            <ResultCard
              title={result.title}
              description={result.description}
              imageLabel={result.imageLabel}
              imageSrc={result.imageSrc}
              tone={result.tone}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
