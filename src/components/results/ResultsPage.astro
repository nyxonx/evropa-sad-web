---
import type { Lang } from '../../i18n/config';
import { getResults } from '../../data';
import CTASection from '../sections/CTASection.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const results = getResults(lang);

const copy = {
  sr: {
    heroKicker: 'REZULTATI',
    heroTitle: 'Dokazi rada koji se vide u brojkama i mjerama',
    heroLead:
      'Rezultati nijesu parole. Ovdje su prikazane mjere, efekti i oblasti u kojima se politika pretvara u konkretan napredak za građane.',
    filtersLabel: 'Filter rezultata',
    filters: {
      all: 'Svi rezultati',
      standard: 'Standard',
      development: 'Investicije',
      economy: 'Ekonomija',
      'quality-of-life': 'Bolji život',
    },
    resultsKicker: 'PREGLED MJERA',
    resultsTitle: 'Konkretni rezultati po oblastima',
    resultsText: 'Filtriraj rezultate po oblasti i otvori detalje za kratak pregled efekata, mjera i dostupnih izvora.',
    detailsCta: 'Detalji',
    closePanel: 'Zatvori',
    panelLabel: 'Detalji rezultata',
    metricsLabel: 'Brojke i indikatori',
    impactLabel: 'Šta pokazuje rezultat',
    sourcesLabel: 'Izvori i verifikacija',
    noSources: 'Izvori za ovu mjeru biće dopunjeni nakon verifikacije.',
    noResults: 'Nema rezultata za izabrani filter.',
    sourcePrefix: 'Izvor',
  },
  en: {
    heroKicker: 'RESULTS',
    heroTitle: 'Proof of work shown through numbers and measures',
    heroLead:
      'Results are not slogans. This page shows measures, effects and areas where policy becomes concrete progress for citizens.',
    filtersLabel: 'Results filter',
    filters: {
      all: 'All results',
      standard: 'Living standards',
      development: 'Investment',
      economy: 'Economy',
      'quality-of-life': 'Better life',
    },
    resultsKicker: 'MEASURE OVERVIEW',
    resultsTitle: 'Concrete results by area',
    resultsText: 'Filter results by area and open details for a short overview of effects, measures and available sources.',
    detailsCta: 'Details',
    closePanel: 'Close',
    panelLabel: 'Result details',
    metricsLabel: 'Figures and indicators',
    impactLabel: 'What the result shows',
    sourcesLabel: 'Sources and verification',
    noSources: 'Sources for this measure will be added after verification.',
    noResults: 'No results for the selected filter.',
    sourcePrefix: 'Source',
  },
} as const;

const t = copy[lang];

const categoryOrder = ['standard', 'development', 'economy', 'quality-of-life'];
const categories = [
  { id: 'all', label: t.filters.all },
  ...categoryOrder
    .filter((category) => results.some((result) => result.category === category))
    .map((category) => ({
      id: category,
      label: t.filters[category as keyof typeof t.filters] ?? category,
    })),
];

const resultDetailsJson = JSON.stringify(results);

const toneClasses: Record<string, string> = {
  people: 'from-[#061632] via-[#0c3c86] to-[#d6ad3b]',
  road: 'from-[#082b63] via-[#4b86bd] to-[#f8fafc]',
  flag: 'from-[#082b63] via-[#d6ad3b] to-[#b91c1c]',
  education: 'from-[#f8fafc] via-[#d7e4f5] to-[#082b63]',
};

const getCategoryLabel = (category: string) => t.filters[category as keyof typeof t.filters] ?? category;
const getToneClass = (tone: string) => toneClasses[tone] ?? toneClasses.people;
---

<section class="relative isolate overflow-hidden bg-[#061632] pb-20 pt-32 text-white sm:pt-36 lg:pt-40">
  <img src="/images/homepage-hero-clean.png" alt="" class="absolute inset-0 -z-30 h-full w-full object-cover opacity-24" loading="eager" />
  <div class="absolute inset-0 -z-20 bg-[linear-gradient(110deg,rgba(6,22,50,0.98)_0%,rgba(8,43,99,0.92)_48%,rgba(6,22,50,0.78)_100%)]"></div>
  <div class="absolute left-1/2 top-24 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-[#d6ad3b]/18 blur-3xl"></div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-28 bg-gradient-to-t from-slate-50 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div>
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#f0cf72]">{t.heroKicker}</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-bold tracking-normal sm:text-5xl lg:text-6xl">{t.heroTitle}</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-blue-50/88">{t.heroLead}</p>
    </div>
  </div>
</section>

<nav class="relative z-20 mx-auto -mt-7 max-w-7xl px-4 sm:px-6 lg:px-8" aria-label={t.filtersLabel} data-results-page>
  <div class="grid gap-2 rounded-lg border border-slate-200 bg-white p-2 shadow-xl shadow-slate-300/50 sm:grid-cols-2 lg:grid-cols-5" role="group" aria-label={t.filtersLabel}>
    {
      categories.map((category, index) => (
        <button
          type="button"
          class:list={[
            'flex min-h-12 items-center justify-center rounded-md px-3 py-2 text-center text-xs font-bold uppercase tracking-[0.12em] transition focus:outline-none focus:ring-2 focus:ring-[#d6ad3b]',
            index === 0 ? 'bg-[#fff8e3] text-[#8a6a13] ring-1 ring-[#d6ad3b]/55' : 'text-[#082b63] hover:bg-[#eef4ff]',
          ]}
          data-result-filter={category.id}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {category.label}
        </button>
      ))
    }
  </div>
</nav>

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#b48924]">{t.resultsKicker}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-normal text-[#061632] sm:text-4xl">{t.resultsTitle}</h2>
        <p class="mt-4 text-base leading-8 text-slate-700">{t.resultsText}</p>
      </div>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        results.map((result) => (
          <article
            class="group flex min-h-full flex-col overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm shadow-slate-200/80 transition duration-300 hover:-translate-y-1 hover:border-[#d6ad3b]/70 hover:shadow-xl hover:shadow-slate-300/70"
            data-result-card
            data-category={result.category}
          >
            <div class:list={['relative aspect-[4/3] overflow-hidden bg-gradient-to-br', getToneClass(result.tone)]}>
              {
                result.imageSrc && (
                  <img
                    src={result.imageSrc}
                    alt=""
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                )
              }
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(6,22,50,0.02)_0%,rgba(6,22,50,0.58)_100%)]"></div>
              <div class="absolute bottom-3 left-3 rounded-sm bg-white/92 px-2.5 py-1 text-[0.65rem] font-bold uppercase tracking-[0.14em] text-[#082b63] shadow-sm">
                {getCategoryLabel(result.category)}
              </div>
            </div>

            <div class="flex flex-1 flex-col p-5">
              <div class="flex flex-wrap gap-2">
                {
                  result.metrics.slice(0, 2).map((metric) => (
                    <span class="rounded-md border border-[#d6ad3b]/40 bg-[#fff8e3] px-3 py-2">
                      <span class="block text-sm font-bold leading-none text-[#061632]">{metric.value}</span>
                      <span class="mt-1 block text-[0.62rem] font-bold uppercase tracking-[0.12em] text-[#8a6a13]">{metric.label}</span>
                    </span>
                  ))
                }
              </div>

              <h3 class="mt-5 text-xl font-bold text-[#061632]">{result.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{result.description}</p>

              <button
                type="button"
                class="mt-6 inline-flex min-h-11 w-fit items-center justify-center gap-3 rounded-md border border-[#082b63]/20 bg-[#061632] px-4 text-xs font-bold uppercase text-white shadow-lg shadow-slate-200/80 transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#082b63] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
                data-result-open={result.slug}
                aria-expanded="false"
                aria-controls="result-detail-panel"
                aria-label={`${result.title}: ${t.detailsCta}`}
              >
                {t.detailsCta}
                <span aria-hidden="true" class="flex h-6 w-6 items-center justify-center rounded-full bg-[#d6ad3b] text-base leading-none text-[#061632]">+</span>
              </button>
            </div>
          </article>
        ))
      }
    </div>

    <p class="mt-8 hidden rounded-lg border border-slate-200 bg-white p-5 text-sm leading-6 text-slate-600 shadow-sm shadow-slate-200/80" data-results-empty>
      {t.noResults}
    </p>
  </div>
</section>

<div id="result-detail-modal" class="fixed inset-0 z-[80] hidden" aria-hidden="true">
  <button type="button" class="absolute inset-0 bg-[#061632]/72 opacity-0 transition-opacity duration-300 lg:pointer-events-none" data-result-overlay aria-label={t.closePanel}></button>
  <aside
    id="result-detail-panel"
    class="absolute inset-x-0 bottom-0 max-h-[92vh] translate-y-full overflow-y-auto rounded-t-2xl border border-white/15 bg-white shadow-2xl shadow-black/30 transition duration-300 lg:inset-y-0 lg:left-auto lg:right-0 lg:h-full lg:max-h-none lg:w-full lg:max-w-xl lg:translate-x-full lg:translate-y-0 lg:rounded-l-2xl lg:rounded-tr-none"
    role="dialog"
    aria-modal="true"
    aria-labelledby="result-detail-title"
    aria-label={t.panelLabel}
    tabindex="-1"
  >
    <div class="relative isolate overflow-hidden bg-[#061632] px-5 py-6 text-white sm:px-7">
      <div class="absolute right-8 top-8 -z-10 h-32 w-32 rounded-full bg-[#d6ad3b]/20 blur-3xl"></div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#f0cf72]" data-result-category></p>
          <h2 id="result-detail-title" class="mt-3 text-3xl font-bold tracking-normal" data-result-title></h2>
        </div>
        <button
          type="button"
          class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-white/20 bg-white/10 text-white transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-white/15 focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2 focus:ring-offset-[#061632]"
          data-result-close
          aria-label={t.closePanel}
        >
          <span aria-hidden="true" class="text-2xl leading-none">&times;</span>
        </button>
      </div>
      <p class="mt-5 text-sm leading-7 text-blue-50/88" data-result-description></p>
    </div>

    <div class="space-y-7 px-5 py-6 sm:px-7">
      <section aria-labelledby="result-metrics-heading">
        <h3 id="result-metrics-heading" class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.metricsLabel}</h3>
        <div class="mt-3 grid gap-3 sm:grid-cols-2" data-result-metrics></div>
      </section>

      <section aria-labelledby="result-impact-heading">
        <h3 id="result-impact-heading" class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.impactLabel}</h3>
        <p class="mt-2 text-sm leading-7 text-slate-700" data-result-body></p>
      </section>

      <section aria-labelledby="result-sources-heading">
        <h3 id="result-sources-heading" class="text-xs font-bold uppercase tracking-[0.18em] text-[#b48924]">{t.sourcesLabel}</h3>
        <ul class="mt-3 space-y-3" data-result-sources></ul>
        <p class="mt-3 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-600" data-result-no-sources>{t.noSources}</p>
      </section>

      <button
        type="button"
        class="inline-flex min-h-11 items-center justify-center rounded-md bg-[#061632] px-5 text-xs font-bold uppercase text-white transition hover:-translate-y-0.5 hover:bg-[#082b63] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2"
        data-result-close
      >
        {t.closePanel}
      </button>
    </div>
  </aside>
</div>

<script id="result-detail-data" type="application/json" set:html={resultDetailsJson}></script>
<script id="result-copy-data" type="application/json" set:html={JSON.stringify({ categories: t.filters, sourcePrefix: t.sourcePrefix })}></script>

<CTASection lang={lang} />

<script>
  const initResultsPage = () => {
    const root = document.querySelector('[data-results-page]');
    if (!root || root.dataset.resultsInitialized === 'true') {
      return;
    }

    root.dataset.resultsInitialized = 'true';

    const detailDataScript = document.getElementById('result-detail-data');
    const copyDataScript = document.getElementById('result-copy-data');
    const modal = document.getElementById('result-detail-modal');
    const panel = document.getElementById('result-detail-panel');
    const overlay = document.querySelector('[data-result-overlay]');
    const filterButtons = Array.from(document.querySelectorAll('[data-result-filter]'));
    const resultCards = Array.from(document.querySelectorAll('[data-result-card]'));
    const detailButtons = Array.from(document.querySelectorAll('[data-result-open]'));
    const closeButtons = Array.from(document.querySelectorAll('[data-result-close]'));
    const emptyState = document.querySelector('[data-results-empty]');

    if (!detailDataScript || !copyDataScript || !modal || !panel || !overlay) {
      return;
    }

    const results = JSON.parse(detailDataScript.textContent || '[]');
    const resultBySlug = new Map(results.map((result) => [result.slug, result]));
    const copy = JSON.parse(copyDataScript.textContent || '{}');
    const fields = {
      category: panel.querySelector('[data-result-category]'),
      title: panel.querySelector('[data-result-title]'),
      description: panel.querySelector('[data-result-description]'),
      metrics: panel.querySelector('[data-result-metrics]'),
      body: panel.querySelector('[data-result-body]'),
      sources: panel.querySelector('[data-result-sources]'),
      noSources: panel.querySelector('[data-result-no-sources]'),
    };
    const focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';
    let activeTrigger = null;
    let closeTimer = null;
    let previousBodyOverflow = '';

    const setText = (element, text) => {
      if (element) {
        element.textContent = text || '';
      }
    };

    const applyFilter = (filter) => {
      let visibleCount = 0;

      resultCards.forEach((card) => {
        const shouldShow = filter === 'all' || card.getAttribute('data-category') === filter;
        card.classList.toggle('hidden', !shouldShow);
        if (shouldShow) {
          visibleCount += 1;
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }

      filterButtons.forEach((button) => {
        const isActive = button.getAttribute('data-result-filter') === filter;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('bg-[#fff8e3]', isActive);
        button.classList.toggle('text-[#8a6a13]', isActive);
        button.classList.toggle('ring-1', isActive);
        button.classList.toggle('ring-[#d6ad3b]/55', isActive);
        button.classList.toggle('text-[#082b63]', !isActive);
        button.classList.toggle('hover:bg-[#eef4ff]', !isActive);
      });
    };

    const renderMetrics = (metrics) => {
      if (!fields.metrics) {
        return;
      }

      fields.metrics.innerHTML = '';
      metrics.forEach((metric) => {
        const item = document.createElement('article');
        item.className = 'rounded-lg border border-[#d6ad3b]/35 bg-[#fff8e3] p-4';

        const value = document.createElement('p');
        value.className = 'text-2xl font-bold tracking-normal text-[#061632]';
        value.textContent = metric.value;

        const label = document.createElement('p');
        label.className = 'mt-1 text-xs font-bold uppercase tracking-[0.13em] text-[#8a6a13]';
        label.textContent = metric.label;

        item.append(value, label);
        fields.metrics.append(item);
      });
    };

    const renderSources = (sources) => {
      if (!fields.sources || !fields.noSources) {
        return;
      }

      fields.sources.innerHTML = '';
      const hasSources = Array.isArray(sources) && sources.length > 0;
      fields.sources.classList.toggle('hidden', !hasSources);
      fields.noSources.classList.toggle('hidden', hasSources);

      if (!hasSources) {
        return;
      }

      sources.forEach((source, index) => {
        const item = document.createElement('li');
        const link = document.createElement('a');
        link.href = source;
        link.target = '_blank';
        link.rel = 'noreferrer';
        link.className = 'inline-flex min-h-10 items-center rounded-md border border-slate-200 bg-white px-3 text-sm font-bold text-[#082b63] transition hover:border-[#d6ad3b] hover:text-[#b48924] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2';
        link.textContent = `${copy.sourcePrefix || 'Source'} ${index + 1}`;
        item.append(link);
        fields.sources.append(item);
      });
    };

    const unlockBodyScroll = () => {
      document.body.style.overflow = previousBodyOverflow;
    };

    const closePanel = () => {
      clearTimeout(closeTimer);
      modal.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0');
      panel.classList.remove('translate-y-0', 'lg:translate-x-0');
      panel.classList.add('translate-y-full', 'lg:translate-x-full');

      detailButtons.forEach((button) => button.setAttribute('aria-expanded', 'false'));

      closeTimer = window.setTimeout(() => {
        modal.classList.add('hidden');
        unlockBodyScroll();
        if (activeTrigger) {
          activeTrigger.focus();
        }
        activeTrigger = null;
      }, 300);
    };

    const openPanel = (slug, trigger) => {
      const result = resultBySlug.get(slug);
      if (!result) {
        return;
      }

      clearTimeout(closeTimer);
      activeTrigger = trigger;
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';

      setText(fields.category, copy.categories?.[result.category] || result.category);
      setText(fields.title, result.title);
      setText(fields.description, result.description);
      setText(fields.body, result.body);
      renderMetrics(result.metrics || []);
      renderSources(result.sources || []);

      detailButtons.forEach((button) => {
        const isActive = button === trigger;
        button.setAttribute('aria-expanded', String(isActive));
      });

      modal.classList.remove('hidden');
      requestAnimationFrame(() => {
        modal.setAttribute('aria-hidden', 'false');
        overlay.classList.remove('opacity-0');
        overlay.classList.add('opacity-100');
        panel.classList.remove('translate-y-full', 'lg:translate-x-full');
        panel.classList.add('translate-y-0', 'lg:translate-x-0');
        const firstControl = panel.querySelector('[data-result-close]');
        if (firstControl) {
          firstControl.focus();
        }
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFilter(button.getAttribute('data-result-filter') || 'all');
      });
    });

    detailButtons.forEach((button) => {
      button.addEventListener('click', () => {
        openPanel(button.getAttribute('data-result-open'), button);
      });
    });

    closeButtons.forEach((button) => button.addEventListener('click', closePanel));
    overlay.addEventListener('click', closePanel);

    document.addEventListener('keydown', (event) => {
      if (modal.getAttribute('aria-hidden') === 'true') {
        return;
      }

      if (event.key === 'Escape') {
        closePanel();
        return;
      }

      if (event.key !== 'Tab') {
        return;
      }

      const focusable = Array.from(panel.querySelectorAll(focusableSelector)).filter((element) => !element.hasAttribute('disabled'));
      if (focusable.length === 0) {
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  };

  document.addEventListener('astro:page-load', initResultsPage);
  initResultsPage();
</script>
