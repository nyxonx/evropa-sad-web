---
const kpis = [
  {
    title: 'Članova',
    value: '25+',
    description: 'hiljada članova',
    icon: 'M10 19v-1.5a4 4 0 0 1 8 0V19M9 8a3 3 0 1 0 6 0 3 3 0 0 0-6 0m8 3a2.5 2.5 0 1 0 3.5 2.3M5 11a2.5 2.5 0 1 1 3.5 2.3',
  },
  {
    title: 'Prosječna zarada',
    value: '1.000€',
    description: 'prosječna zarada',
    icon: 'M4 20h16M7 16v-5m5 5V7m5 9v7M5 12l7-7 3 3 4-4',
  },
  {
    title: 'Minimalna zarada',
    value: '+60%',
    description: 'minimalna zarada',
    icon: 'M6 7h12v10H6zM9 7V5h6v2m-6 5h6m-6 3h4',
  },
  {
    title: 'Rast zaposlenosti',
    value: '+13,6%',
    description: 'rast zaposlenosti',
    icon: 'M4 17l5-5 4 4 7-9m0 0h-5m5 0v5',
  },
  {
    title: 'Investicije',
    value: '+44,4%',
    description: 'strane investicije',
    icon: 'M4 18l5-6 4 3 7-9m0 0h-5m5 0v5',
  },
  {
    title: 'Evropski put',
    value: '33/33',
    description: 'EU poglavlja',
    icon: 'M12 3l2.3 5 5.4.7-4 3.8 1 5.4L12 14.6 7.3 17l1-5.4-4-3.8 5.4-.7z',
  },
];
---

<section class="relative z-20 -mt-10 bg-[linear-gradient(to_bottom,transparent_0,transparent_2.5rem,#f8fafc_2.5rem,#f8fafc_100%)] pb-12 sm:-mt-12 sm:bg-[linear-gradient(to_bottom,transparent_0,transparent_3rem,#f8fafc_3rem,#f8fafc_100%)] sm:pb-14 lg:-mt-12 lg:pb-20" aria-labelledby="kpi-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="overflow-hidden rounded-xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/12 ring-1 ring-white/80">
      <div class="sr-only">
        <h2 id="kpi-heading">Ključni pokazatelji</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-6">
      {
        kpis.map((kpi) => (
          <article class="group flex min-h-28 flex-col items-center justify-center border-t border-slate-200 px-4 pb-4 pt-3 text-center transition duration-300 first:border-t-0 hover:bg-[#fff8e3] sm:[&:nth-child(-n+2)]:border-t-0 sm:[&:nth-child(even)]:border-l lg:border-l lg:border-t-0 lg:first:border-l-0">
            <div class="-mt-2 flex h-9 w-9 items-center justify-center text-[#082b63] transition duration-300 group-hover:-translate-y-1 group-hover:text-[#b48924]">
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-7 w-7 fill-none stroke-current stroke-[1.9]">
                <path d={kpi.icon} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <p class="mt-1.5 text-2xl font-bold leading-none tracking-normal text-[#082b63] lg:text-3xl">{kpi.value}</p>
            <h3 class="mt-1.5 text-xs font-bold text-slate-900 sm:text-sm">{kpi.title}</h3>
            <p class="mt-1 max-w-[8rem] text-xs leading-4 text-slate-600">{kpi.description}</p>
          </article>
        ))
      }
      </div>
    </div>
  </div>
</section>
