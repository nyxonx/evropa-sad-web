---
import { type Lang } from '../../i18n/config';
import { translations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang].kpi;
---

<section class="relative z-20 -mt-10 bg-[linear-gradient(to_bottom,transparent_0,transparent_2.5rem,#f8fafc_2.5rem,#f8fafc_100%)] pb-12 sm:-mt-12 sm:bg-[linear-gradient(to_bottom,transparent_0,transparent_3rem,#f8fafc_3rem,#f8fafc_100%)] sm:pb-14 lg:-mt-12 lg:pb-20" aria-labelledby="kpi-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="overflow-hidden rounded-xl border border-slate-200/90 bg-white shadow-2xl shadow-slate-900/12 ring-1 ring-white/80">
      <div class="sr-only">
        <h2 id="kpi-heading">{t.heading}</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
        {
          t.items.map((kpi) => (
            <article class="group flex min-h-28 flex-col items-center justify-center border-t border-slate-200 px-3 pb-4 pt-3 text-center transition duration-300 first:border-t-0 hover:bg-[#fff8e3] even:border-l sm:px-4 md:[&:nth-child(-n+3)]:border-t-0 md:[&:nth-child(odd)]:border-l-0 md:[&:nth-child(3n+1)]:border-l-0 lg:border-l lg:border-t-0 lg:first:border-l-0">
              <div class="-mt-2 flex h-9 w-9 items-center justify-center text-[#082b63] transition duration-300 group-hover:-translate-y-1 group-hover:text-[#b48924]">
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-7 w-7 fill-none stroke-current stroke-[1.9]">
                  <path d={kpi.icon} stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <p class="mt-1.5 text-2xl font-bold leading-none tracking-normal text-[#082b63] lg:text-[1.7rem]">
                {kpi.value}
              </p>
              <h3 class="mt-1.5 text-xs font-bold leading-tight text-slate-950 sm:text-sm">{kpi.title}</h3>
              <p class="mt-1 max-w-[8rem] text-xs leading-4 text-slate-600">{kpi.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
