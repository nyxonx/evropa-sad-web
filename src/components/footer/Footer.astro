---
const footerColumns = [
  {
    title: 'Program',
    links: [
      { href: '/program', label: 'Prioriteti' },
      { href: '/rezultati', label: 'Rezultati' },
      { href: '/dokumenti', label: 'Dokumenti' },
    ],
  },
  {
    title: 'Organizacija',
    links: [
      { href: '/organizacija', label: 'Predsjedništvo' },
      { href: '/organizacija#odbori', label: 'Odbori' },
      { href: '/kontakt', label: 'Lokalni odbori' },
    ],
  },
  {
    title: 'Aktuelnosti',
    links: [
      { href: '/vijesti', label: 'Vijesti' },
      { href: '/saopstenja', label: 'Saopštenja' },
      { href: '/dogadjaji', label: 'Događaji' },
    ],
  },
  {
    title: 'Dokumenta',
    links: [
      { href: '/dokumenti', label: 'Sva dokumenta' },
      { href: '/dokumenti#statut', label: 'Statut' },
      { href: '/dokumenti#program', label: 'Program rada' },
    ],
  },
];

const socialLinks = [
  { href: 'https://www.facebook.com/', label: 'Facebook' },
  { href: 'https://www.instagram.com/', label: 'Instagram' },
  { href: 'https://www.youtube.com/', label: 'YouTube' },
  { href: 'https://www.linkedin.com/', label: 'LinkedIn' },
];

const legalLinks = [
  { href: '/privatnost', label: 'Politika privatnosti' },
  { href: '/uslovi-koriscenja', label: 'Uslovi korišćenja' },
  { href: '/kolacici', label: 'Kolačići' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-[#061b3d] text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_2fr]">
      <div>
        <a href="/" class="inline-flex items-center gap-3" aria-label="Evropa Sad - naslovna">
          <span class="flex h-11 w-11 items-center justify-center rounded-sm bg-white text-sm font-bold text-[#082b63]">
            ES
          </span>
          <span class="flex flex-col leading-tight">
            <span class="text-base font-bold uppercase tracking-wide text-white">Evropa Sad</span>
            <span class="text-xs font-medium uppercase text-[#d6ad3b]">Zvanični portal</span>
          </span>
        </a>

        <p class="mt-5 max-w-sm text-sm leading-6 text-slate-300">
          Institucionalna platforma za program, rezultate, organizaciju i javne aktivnosti Pokreta Evropa Sad.
        </p>

        <address class="mt-6 not-italic text-sm leading-6 text-slate-300">
          <span class="block font-semibold text-white">Kontakt</span>
          <a href="mailto:info@evropasad.me" class="transition hover:text-[#d6ad3b]">info@evropasad.me</a>
          <span class="block">Podgorica, Crna Gora</span>
        </address>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          footerColumns.map((column) => (
            <section aria-labelledby={`footer-${column.title.toLowerCase()}`}>
              <h2 id={`footer-${column.title.toLowerCase()}`} class="text-sm font-bold uppercase tracking-wide text-[#d6ad3b]">
                {column.title}
              </h2>
              <ul class="mt-4 space-y-3">
                {
                  column.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-sm text-slate-300 transition hover:text-white">
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </section>
          ))
        }
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <nav aria-label="Društvene mreže">
          <ul class="flex flex-wrap gap-x-5 gap-y-2">
            {
              socialLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-sm font-semibold text-slate-300 transition hover:text-[#d6ad3b]">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav aria-label="Pravni linkovi">
          <ul class="flex flex-wrap gap-x-5 gap-y-2">
            {
              legalLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-slate-300 transition hover:text-white">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <p class="mt-6 text-sm text-slate-400">© {currentYear} Evropa Sad. Sva prava zadržana.</p>
    </div>
  </div>
</footer>
