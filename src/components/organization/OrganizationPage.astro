      lang === 'sr'
        ? ['sprovodi odluke', 'jača infrastrukturu', 'koordinira aktivnosti']
        : ['implements decisions', 'strengthens infrastructure', 'coordinates activities'],
    responsibilities:
      lang === 'sr'
        ? ['sprovodi odluke nadležnih organa', 'koordinira kampanje, logistiku i teren', 'jača organizacionu mrežu i operativne kapacitete']
