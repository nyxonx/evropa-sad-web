    role:
      lang === 'sr'
        ? 'Čuva odgovornost u finansijama, imovini i izvještavanju prema organima Pokreta.'
        : 'Protects accountability in finances, assets and reporting to Movement bodies.',
    bullets:
      lang === 'sr'
        ? ['prati finansije', 'kontroliše imovinu', 'izvještava organe']
        : ['monitors finances', 'controls assets', 'reports to bodies'],
    responsibilities:
      lang === 'sr'
        ? ['prati finansijsko poslovanje', 'kontroliše upravljanje imovinom', 'priprema nalaze i izvještaje za nadležne organe']
        : ['monitors financial operations', 'controls asset management', 'prepares findings and reports for competent bodies'],
    composition:
      lang === 'sr'
        ? ['članovi Nadzornog odbora', 'tim zadužen za pregled finansija i imovine', 'komunikacija sa organima koji razmatraju izvještaje']
        : ['Supervisory board members', 'a team responsible for reviewing finances and assets', 'communication with bodies that review reports'],
    mandate:
      lang === 'sr'
        ? 'Radi kroz redovne kontrole i izvještavanje o finansijskom poslovanju i imovini.'
        : 'Works through regular controls and reporting on financial operations and assets.',
    connection:
      lang === 'sr'
        ? 'Izvještava nadležne organe i čuva povjerenje u odgovorno upravljanje resursima.'
        : 'Reports to competent bodies and protects trust in responsible resource management.',
    icon: 'M12 3 5 6v5c0 4.4 3 8.4 7 10 4-1.6 7-5.6 7-10V6l-7-3Z',
  },
