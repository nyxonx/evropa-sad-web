    mandate:
      lang === 'sr'
        ? 'Radi kroz operativne planove, zadatke i dinamiku koju određuju nadležni organi.'
        : 'Works through operational plans, assignments and pace defined by competent bodies.',
    connection:
      lang === 'sr'
        ? 'Preuzima političke smjernice Predsjedništva i Glavnog odbora i pretvara ih u aktivnosti.'
        : 'Takes political guidance from the Presidency and Main board and turns it into activities.',
    icon: 'M5 7h14v12H5zM8 7V5h8v2M8 12h8M8 16h5',
  },
  {
    id: 'statutarna-komisija',
    title: lang === 'sr' ? 'Statutarna komisija' : 'Statutory commission',
    label: lang === 'sr' ? 'tumačenje akata' : 'interpretation of acts',
    description:
      lang === 'sr'
        ? 'Čuva pravila unutrašnjeg sistema. Tumači Statut, prati usklađenost akata i rješava pitanja nadležnosti.'
        : 'Protects the rules of the internal system. It interprets the Statute, monitors act alignment and resolves competence questions.',
    role:
      lang === 'sr'
        ? 'Obezbjeđuje da unutrašnja pravila budu jasna, dosljedna i primjenjiva u radu organa.'
        : 'Ensures internal rules remain clear, consistent and applicable in the work of bodies.',
    bullets:
      lang === 'sr'
        ? ['čuva pravila sistema', 'tumači akte', 'prati usklađenost']
        : ['protects internal rules', 'interprets acts', 'monitors alignment'],
    responsibilities:
      lang === 'sr'
        ? ['tumači Statut i unutrašnja pravila', 'prati usklađenost opštih akata', 'rješava pitanja nadležnosti u sistemu']
        : ['interprets the Statute and internal rules', 'monitors alignment of general acts', 'resolves competence questions in the system'],
    composition:
      lang === 'sr'
        ? ['članovi sa iskustvom u pravilima, procedurama i unutrašnjim aktima', 'tijelo koje samostalno razmatra statutarna pitanja', 'stručna podrška organima kada je potrebno tumačenje']
        : ['members experienced in rules, procedures and internal acts', 'a body that independently reviews statutory questions', 'expert support to bodies when interpretation is needed'],
    mandate:
      lang === 'sr'
        ? 'Postupa kada je potrebno tumačenje pravila, usklađivanje akata ili rješavanje pitanja nadležnosti.'
        : 'Acts when rule interpretation, act alignment or competence resolution is needed.',
    connection:
      lang === 'sr'
        ? 'Pomaže organima da odluke ostanu usklađene sa unutrašnjim pravilima.'
