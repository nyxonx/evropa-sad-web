<script>
  const initOrganizationPanel = () => {
    const dataScript = document.getElementById('organization-organ-data');
    const modal = document.getElementById('organization-detail-modal');
    const panel = document.getElementById('organization-detail-panel');
    const overlay = document.querySelector('[data-organ-overlay]');
    const triggers = Array.from(document.querySelectorAll('[data-organ-trigger]'));
    const closeButtons = Array.from(document.querySelectorAll('[data-organ-close]'));

    if (!dataScript || !modal || !panel || !overlay || triggers.length === 0) {
      return;
    }

    const organs = JSON.parse(dataScript.textContent || '[]');
    const organById = new Map(organs.map((organ) => [organ.id, organ]));
    const fields = {
      label: panel.querySelector('[data-organ-label]'),
      title: panel.querySelector('[data-organ-title]'),
      description: panel.querySelector('[data-organ-description]'),
      role: panel.querySelector('[data-organ-role]'),
      responsibilities: panel.querySelector('[data-organ-responsibilities]'),
      composition: panel.querySelector('[data-organ-composition]'),
      mandate: panel.querySelector('[data-organ-mandate]'),
      mandateBlock: panel.querySelector('[data-organ-mandate-block]'),
      connection: panel.querySelector('[data-organ-connection]'),
    };
    const focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';
    let activeTrigger = null;
    let closeTimer = null;
    let previousBodyOverflow = '';

    const setText = (element, text) => {
      if (element) {
        element.textContent = text || '';
      }
    };

    const renderList = (element, items) => {
      if (!element) {
        return;
      }

      element.innerHTML = '';
      items.forEach((item) => {
        const listItem = document.createElement('li');
        listItem.className = 'flex gap-3 text-sm leading-6 text-slate-700';

        const dot = document.createElement('span');
        dot.className = 'mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#d6ad3b]';
        dot.setAttribute('aria-hidden', 'true');

        const text = document.createElement('span');
        text.textContent = item;

        listItem.append(dot, text);
        element.append(listItem);
      });
    };

    const updateTriggerStates = (activeId) => {
      triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-organ-trigger') === activeId;
        trigger.setAttribute('aria-expanded', String(isActive));
        trigger.classList.toggle('border-[#d6ad3b]', isActive);
        trigger.classList.toggle('bg-[#082b63]', isActive);
      });
    };

    const renderOrgan = (organ) => {
      setText(fields.label, organ.label);
      setText(fields.title, organ.title);
      setText(fields.description, organ.description);
      setText(fields.role, organ.role);
      setText(fields.mandate, organ.mandate);
      setText(fields.connection, organ.connection);
      renderList(fields.responsibilities, organ.responsibilities || []);
      renderList(fields.composition, organ.composition || []);

      if (fields.mandateBlock) {
        fields.mandateBlock.hidden = !organ.mandate;
      }
    };

    const openPanel = (organId, trigger) => {
      const organ = organById.get(organId);
      if (!organ) {
        return;
      }

      window.clearTimeout(closeTimer);
      activeTrigger = trigger;
      renderOrgan(organ);
      updateTriggerStates(organId);
      const wasClosed = modal.classList.contains('hidden');
      if (wasClosed) {
        previousBodyOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        modal.classList.remove('hidden');
      }
      modal.setAttribute('aria-hidden', 'false');

      window.requestAnimationFrame(() => {
        overlay.classList.add('opacity-100');
        panel.classList.remove('translate-y-full', 'lg:translate-x-full');
        panel.classList.add('translate-y-0', 'lg:translate-x-0');
      });

      const firstControl = panel.querySelector('[data-organ-close]');
      (firstControl || panel).focus();
    };

    const closePanel = () => {
      if (modal.classList.contains('hidden')) {
        return;
      }

      overlay.classList.remove('opacity-100');
      panel.classList.add('translate-y-full', 'lg:translate-x-full');
      panel.classList.remove('translate-y-0', 'lg:translate-x-0');
      modal.setAttribute('aria-hidden', 'true');
      updateTriggerStates('');
      document.body.style.overflow = previousBodyOverflow;

      closeTimer = window.setTimeout(() => {
        modal.classList.add('hidden');
      }, 250);

      if (activeTrigger) {
        activeTrigger.focus();
      }
      activeTrigger = null;
    };

    const trapFocus = (event) => {
      if (modal.classList.contains('hidden') || event.key !== 'Tab') {
        return;
      }

      const focusable = Array.from(panel.querySelectorAll(focusableSelector)).filter((element) => element.offsetParent !== null);
      if (focusable.length === 0) {
        event.preventDefault();
        panel.focus();
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        openPanel(trigger.getAttribute('data-organ-trigger'), trigger);
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener('click', closePanel);
    });

    overlay.addEventListener('click', closePanel);

    document.addEventListener(
      'click',
      (event) => {
        if (modal.classList.contains('hidden') || window.matchMedia('(max-width: 1023px)').matches) {
          return;
        }

        const target = event.target;
        if (!(target instanceof Element) || panel.contains(target) || target.closest('[data-organ-trigger]')) {
          return;
        }

        event.preventDefault();
        event.stopPropagation();
        closePanel();
      },
      true,
    );

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closePanel();
      }
      trapFocus(event);
    });
  };

  const initLocalBoardExpansion = () => {
    const showTrigger = document.querySelector('[data-local-show-all]');
    const hideTrigger = document.querySelector('[data-local-hide-all]');
    const extraBoards = Array.from(document.querySelectorAll('[data-local-board-extra]'));

    if (!showTrigger || !hideTrigger || extraBoards.length === 0) {
      return;
    }

    showTrigger.addEventListener('click', () => {
      extraBoards.forEach((board) => {
        board.classList.remove('hidden');
      });
      showTrigger.setAttribute('aria-expanded', 'true');
      showTrigger.classList.add('hidden');
      hideTrigger.classList.remove('hidden');
      hideTrigger.classList.add('flex');
    });

    hideTrigger.addEventListener('click', () => {
      extraBoards.forEach((board) => {
        board.classList.add('hidden');
      });
      showTrigger.setAttribute('aria-expanded', 'false');
      hideTrigger.classList.add('hidden');
      hideTrigger.classList.remove('flex');
      showTrigger.classList.remove('hidden');
      showTrigger.focus();
    });
  };

  const initOrganizationMembersModal = () => {
    const organDataScript = document.getElementById('organization-organ-data');
    const memberDataScript = document.getElementById('organization-member-data');
    const modal = document.getElementById('organization-members-modal');
    const dialog = document.getElementById('organization-members-dialog');
    const overlay = document.querySelector('[data-members-overlay]');
    const triggers = Array.from(document.querySelectorAll('[data-members-trigger]'));
    const closeButtons = Array.from(document.querySelectorAll('[data-members-close]'));
    const title = document.querySelector('[data-members-title]');
    const grid = document.querySelector('[data-members-grid]');
    const empty = document.querySelector('[data-members-empty]');

    if (!organDataScript || !memberDataScript || !modal || !dialog || !overlay || !title || !grid || !empty) {
      return;
    }

    const organs = JSON.parse(organDataScript.textContent || '[]');
    const members = JSON.parse(memberDataScript.textContent || '[]');
    const organById = new Map(organs.map((organ) => [organ.id, organ]));
    const membersByBody = new Map();
    const defaultEmptyText = empty.getAttribute('data-default-empty') || empty.textContent;
    const focusableSelector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])';
    let activeTrigger = null;
    let closeTimer = null;
    let previousBodyOverflow = '';

    members.forEach((member) => {
      if (!member.bodyId) {
        return;
      }

      const bodyMembers = membersByBody.get(member.bodyId) || [];
      bodyMembers.push(member);
      membersByBody.set(member.bodyId, bodyMembers);
    });

    const getInitials = (name) =>
      String(name || '')
        .trim()
        .split(/\s+/)
        .slice(0, 2)
        .map((part) => part.charAt(0))
        .join('')
        .toUpperCase();

    const createSocialIcon = (label) => {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('aria-hidden', 'true');
      svg.setAttribute('class', 'h-4 w-4 fill-none stroke-current stroke-[1.8]');

      const addPath = (d) => {
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', d);
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        svg.append(path);
      };

      const addCircle = (cx, cy, r) => {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', cx);
        circle.setAttribute('cy', cy);
        circle.setAttribute('r', r);
        svg.append(circle);
      };

      const addRect = (x, y, width, height, rx = '0') => {
        const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rect.setAttribute('x', x);
        rect.setAttribute('y', y);
        rect.setAttribute('width', width);
        rect.setAttribute('height', height);
        rect.setAttribute('rx', rx);
        svg.append(rect);
      };

      const key = String(label || '').toLowerCase();
      if (key.includes('instagram')) {
        addRect('3', '3', '18', '18', '5');
        addCircle('12', '12', '4');
        addCircle('17.5', '6.5', '0.7');
      } else if (key.includes('linkedin')) {
        addPath('M16 8a5 5 0 0 1 5 5v7h-4v-7a1.8 1.8 0 0 0-3.6 0v7h-4v-7a5 5 0 0 1 5-5Z');
        addPath('M3 9h4v11H3Z');
        addCircle('5', '5', '2');
      } else if (key.includes('facebook')) {
        addPath('M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3Z');
      } else {
        addPath('M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1');
        addPath('M14 11a5 5 0 0 0-7.1 0l-2 2a5 5 0 0 0 7.1 7.1l1.1-1.1');
      }

      return svg;
    };

    const createMemberCard = (member) => {
      const card = document.createElement('article');
      card.className =
        'rounded-xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/80 transition duration-300 hover:-translate-y-0.5 hover:border-[#d6ad3b]/70 hover:shadow-lg hover:shadow-slate-300/70';

      const row = document.createElement('div');
      row.className = 'flex items-start gap-4';

      const avatar = document.createElement('div');
      avatar.className =
        'relative flex h-24 w-24 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-[#061632] text-lg font-bold text-[#f0cf72] ring-1 ring-[#d6ad3b]/40';

      const initials = document.createElement('span');
      initials.textContent = getInitials(member.name) || 'ES';
      avatar.append(initials);

      if (member.image) {
        const image = document.createElement('img');
        image.src = member.image;
        image.alt = member.name || '';
        image.loading = 'lazy';
        image.className = 'absolute inset-0 h-full w-full object-cover';
        image.addEventListener('error', () => {
          image.remove();
        });
        avatar.append(image);
      }

      const content = document.createElement('div');
      content.className = 'min-w-0 flex-1';

      const name = document.createElement('h3');
      name.className = 'truncate text-base font-bold leading-6 text-[#061632]';
      name.textContent = member.name;

      const role = document.createElement('p');
      role.className = 'mt-1 truncate text-xs font-bold uppercase tracking-[0.12em] text-[#b48924]';
      role.textContent = member.role;

      content.append(name, role);

      if (member.responsibility) {
        const responsibility = document.createElement('p');
        responsibility.className = 'mt-2 truncate text-sm leading-6 text-slate-600';
        responsibility.textContent = member.responsibility;
        content.append(responsibility);
      }

      if (member.bioUrl) {
        const link = document.createElement('a');
        link.href = member.bioUrl;
        link.className =
          'mt-3 inline-flex min-h-8 items-center justify-center rounded-md border border-[#082b63]/20 px-3 text-[0.7rem] font-bold uppercase text-[#082b63] transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#fff8e3] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2';
        link.textContent = dialog.getAttribute('data-biography-label') || 'Biografija';
        content.append(link);
      }

      if (member.socials?.length) {
        const socials = document.createElement('div');
        socials.className = 'mt-3 flex flex-wrap gap-2';

        member.socials.forEach((social) => {
          const socialLink = document.createElement('a');
          socialLink.href = social.href;
          socialLink.target = '_blank';
          socialLink.rel = 'noreferrer';
          socialLink.className =
            'inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#082b63]/15 bg-slate-50 text-[#082b63] transition hover:-translate-y-0.5 hover:border-[#d6ad3b] hover:bg-[#fff8e3] hover:text-[#061632] focus:outline-none focus:ring-2 focus:ring-[#d6ad3b] focus:ring-offset-2';
          socialLink.setAttribute('aria-label', `${member.name}: ${social.label}`);
          socialLink.append(createSocialIcon(social.label));
          socials.append(socialLink);
        });

        content.append(socials);
      }

      row.append(avatar, content);
      card.append(row);

      return card;
    };

    const renderMembers = (bodyId) => {
      const bodyMembers = membersByBody.get(bodyId) || [];
      grid.innerHTML = '';
      empty.textContent = organById.get(bodyId)?.emptyText || defaultEmptyText;
      grid.classList.toggle('hidden', bodyMembers.length === 0);
      empty.classList.toggle('hidden', bodyMembers.length > 0);

      bodyMembers.forEach((member) => {
        grid.append(createMemberCard(member));
      });
    };

    const updateTriggerStates = (activeId) => {
      triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-members-trigger') === activeId;
        trigger.setAttribute('aria-expanded', String(isActive));
      });
    };

    const openModal = (bodyId, trigger) => {
      const organ = organById.get(bodyId);
      if (!organ) {
        return;
      }

      window.clearTimeout(closeTimer);
      activeTrigger = trigger;
      title.textContent = organ.title;
      renderMembers(bodyId);
      updateTriggerStates(bodyId);
      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');

      window.requestAnimationFrame(() => {
        overlay.classList.add('opacity-100');
        dialog.classList.remove('translate-y-full', 'sm:-translate-y-[46%]', 'sm:scale-95', 'sm:opacity-0');
        dialog.classList.add('translate-y-0', 'sm:-translate-y-1/2', 'sm:scale-100', 'sm:opacity-100');
      });

      const firstControl = dialog.querySelector('[data-members-close]');
      (firstControl || dialog).focus();
    };

    const closeModal = () => {
      if (modal.classList.contains('hidden')) {
        return;
      }

      overlay.classList.remove('opacity-100');
      dialog.classList.add('translate-y-full', 'sm:-translate-y-[46%]', 'sm:scale-95', 'sm:opacity-0');
      dialog.classList.remove('translate-y-0', 'sm:-translate-y-1/2', 'sm:scale-100', 'sm:opacity-100');
      modal.setAttribute('aria-hidden', 'true');
      updateTriggerStates('');
      document.body.style.overflow = previousBodyOverflow;

      closeTimer = window.setTimeout(() => {
        modal.classList.add('hidden');
      }, 250);

      if (activeTrigger) {
        activeTrigger.focus();
      }
      activeTrigger = null;
    };

    const trapFocus = (event) => {
      if (modal.classList.contains('hidden') || event.key !== 'Tab') {
        return;
      }

      const focusable = Array.from(dialog.querySelectorAll(focusableSelector)).filter((element) => element.offsetParent !== null);
      if (focusable.length === 0) {
        event.preventDefault();
        dialog.focus();
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        openModal(trigger.getAttribute('data-members-trigger'), trigger);
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener('click', closeModal);
    });

    overlay.addEventListener('click', closeModal);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeModal();
      }
      trapFocus(event);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initOrganizationPanel();
      initLocalBoardExpansion();
      initOrganizationMembersModal();
    });
  } else {
    initOrganizationPanel();
    initLocalBoardExpansion();
    initOrganizationMembersModal();
  }
</script>
