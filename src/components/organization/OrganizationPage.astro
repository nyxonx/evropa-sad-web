const hiddenLocalBoardIds = new Set(['odbor-gusinje', 'odbor-petnjica', 'odbor-tuzi', 'odbor-ulcinj']);
const visibleLocalBoards = organization.localBoards.filter((board) => !hiddenLocalBoardIds.has(board.id));
const featuredLocalBoards = visibleLocalBoards.filter((board) => board.featured);
const otherLocalBoards = visibleLocalBoards.filter((board) => !board.featured);

const localBoardBodies = organization.localBoards.map((board) => ({
  id: board.id,
  title: board.title,
  label: lang === 'sr' ? 'lokalni odbor' : 'local board',
  isLocalBoard: true,
  emptyText: t.localMembersEmpty,
}));

const expertBodies = [
  {
    title: lang === 'sr' ? 'Forumi' : 'Forums',
    text:
      lang === 'sr'
        ? 'Okupljaju članove i simpatizere oko posebnih društvenih i programskih tema.'
        : 'Bring members and supporters together around specific social and program topics.',
    icon: 'M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM3 21a5 5 0 0 1 10 0m-2 0a5 5 0 0 1 10 0',
  },
  {
    title: lang === 'sr' ? 'Savjeti' : 'Councils',
    text:
      lang === 'sr'
        ? 'Razrađuju javne politike, inicijative i stručne preporuke po oblastima.'
        : 'Develop public policies, initiatives and expert recommendations by field.',
    icon: 'M12 3l2.3 5 5.4.7-4 3.8 1 5.4L12 14.6 7.3 17l1-5.4-4-3.8 5.4-.7z',
  },
  {
    title: lang === 'sr' ? 'Sekretarijati i stručni timovi' : 'Secretariats and expert teams',
    text:
      lang === 'sr'
        ? 'Pomažu da ideje postanu programi, operativni planovi i konkretan rad.'
        : 'Help ideas become programs, operational plans and concrete work.',
    icon: 'M4 7h16M7 7v10m5-10v10m5-10v10M5 17h14',
  },
];

const processSteps = [
  {
    title: lang === 'sr' ? 'Politički pravac' : 'Political direction',
    text: lang === 'sr' ? 'definišu ga organi koji vode politiku' : 'defined by the bodies leading policy',
  },
  {
    title: lang === 'sr' ? 'Odluka organa' : 'Body decision',
    text: lang === 'sr' ? 'pretvara pravac u jasan zadatak' : 'turns direction into a clear task',
  },
  {
    title: lang === 'sr' ? 'Operativno sprovođenje' : 'Operational implementation',
    text: lang === 'sr' ? 'Izvršni odbor vodi realizaciju' : 'the Executive board leads delivery',
  },
  {
    title: lang === 'sr' ? 'Lokalna koordinacija' : 'Local coordination',
    text: lang === 'sr' ? 'odbori prilagođavaju rad terenu' : 'boards adapt work to the field',
  },
  {
    title: lang === 'sr' ? 'Komunikacija sa građanima' : 'Citizen communication',
    text: lang === 'sr' ? 'povratne informacije se vraćaju u sistem' : 'feedback returns into the system',
  },
];

const organDetailsJson = JSON.stringify([...stateBodies, ...localBoardBodies]);
const stateBodyMembers = organization.bodies.flatMap((body) =>
  body.members
    .filter((member) => member.person)
    .map((member) => ({
      name: member.person?.name ?? '',
      role: member.role || member.person?.role || '',
      bodyId: body.id,
      image: member.person?.imageSrc ?? '',
      responsibility: member.responsibility ?? '',
      bioUrl: member.bioUrl ?? '',
      email: member.email ?? '',
      socials: member.socials?.length ? member.socials : (member.person?.links ?? []),
    })),
);
const localBoardMembers = organization.localBoards.flatMap((board) =>
  board.members
    .filter((member) => member.person)
    .map((member) => ({
      name: member.person?.name ?? '',
      role: member.role || member.person?.role || '',
      bodyId: board.id,
      image: member.person?.imageSrc ?? '',
      responsibility: member.responsibility ?? '',
      bioUrl: member.bioUrl ?? '',
      email: member.email ?? '',
      socials: member.socials?.length ? member.socials : (member.person?.links ?? []),
    })),
);
const organizationMembers = [...stateBodyMembers, ...localBoardMembers];
const organizationMembersJson = JSON.stringify(organizationMembers);
