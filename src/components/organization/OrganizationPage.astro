  },
  {
    id: 'izvrsni-odbor',
    title: lang === 'sr' ? 'Izvršni odbor' : 'Executive board',
    label: lang === 'sr' ? 'operativno sprovođenje' : 'operational implementation',
    description:
      lang === 'sr'
        ? 'Operativni motor organizacije. Sprovodi odluke, jača infrastrukturu i koordinira aktivnosti na terenu.'
