const systemFlow = [
  {
    title: lang === 'sr' ? 'Skupština' : 'Assembly',
    tag: lang === 'sr' ? 'odlučuje' : 'decides',
    short: lang === 'sr' ? 'najviše izborno tijelo' : 'highest electoral body',
