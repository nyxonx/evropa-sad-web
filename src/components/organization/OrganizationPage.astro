  },
  {
    id: 'nadzorni-odbor',
    title: lang === 'sr' ? 'Nadzorni odbor' : 'Supervisory board',
    label: lang === 'sr' ? 'finansijski nadzor' : 'financial oversight',
    description:
      lang === 'sr'
        ? 'Kontrolni mehanizam Pokreta. Prati finansijsko poslovanje i upravljanje imovinom.'
