---
import { type Lang } from '../../i18n/config';
import { localizePath } from '../../i18n/routing';
import { translations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang].europeVision;
const europeMapImage = '/images/europe-map-stars.png';
---

<section
  class="relative isolate overflow-hidden bg-[#06245a] py-12 text-white sm:py-14 lg:py-16"
  aria-labelledby="europe-vision-heading"
>
  <div class="absolute inset-0 -z-20 bg-[#061632]"></div>
  <div class="absolute inset-0 -z-20 bg-[linear-gradient(90deg,#061632_0%,#071d45_36%,#082d6b_68%,#0b4ea5_100%)]"></div>

  <img
    src={europeMapImage}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-y-0 right-0 -z-10 hidden h-full w-[40%] object-cover object-right opacity-72 mix-blend-screen [mask-image:linear-gradient(90deg,transparent_0%,rgba(0,0,0,0.35)_18%,#000_44%)] lg:block"
    loading="lazy"
  />
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,#061632_0%,rgba(6,22,50,0.98)_30%,rgba(6,22,50,0.76)_52%,rgba(6,22,50,0.24)_76%,rgba(6,22,50,0.04)_100%)]"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_82%_45%,rgba(214,173,59,0.14),transparent_18rem),radial-gradient(circle_at_66%_50%,rgba(24,92,192,0.36),transparent_26rem),linear-gradient(180deg,rgba(6,22,50,0)_0%,rgba(4,17,38,0.36)_100%)]"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-9 lg:grid-cols-[1fr_auto] lg:items-center">
      <div class="max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#d6ad3b]">{t.label}</p>
        <h2 id="europe-vision-heading" class="mt-3 text-3xl font-bold tracking-normal sm:text-4xl">
          {t.title}
        </h2>
        <p class="mt-5 max-w-3xl text-base leading-8 text-blue-50/90">{t.text}</p>
      </div>

      <a
        href={localizePath(lang, t.cta.href)}
        class="inline-flex min-h-12 w-fit items-center justify-center gap-4 rounded-md bg-[#d6ad3b] px-7 text-sm font-bold uppercase text-[#061632] shadow-lg shadow-[#02112d]/25 transition duration-300 hover:-translate-y-0.5 hover:bg-[#f0c84d] focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#082b63]"
      >
        {t.cta.label}
        <span aria-hidden="true" class="text-xl leading-none">→</span>
      </a>
    </div>
  </div>
</section>
