---
import { type Lang } from '../../i18n/config';
import { localizePath } from '../../i18n/routing';
import { translations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang].cta;
---

<section class="bg-slate-50 pb-16 sm:pb-20" aria-labelledby="join-movement-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative isolate overflow-hidden rounded-lg bg-[#082b63] px-5 py-7 text-white shadow-xl shadow-slate-300/70 sm:px-8 lg:px-10">
      <div class="absolute inset-0 -z-20 bg-[linear-gradient(105deg,#061632_0%,#082b63_48%,#0b3f91_100%)]"></div>
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_18%_50%,rgba(214,173,59,0.18),transparent_13rem),radial-gradient(circle_at_82%_44%,rgba(255,255,255,0.12),transparent_18rem),linear-gradient(90deg,rgba(6,22,50,0.55)_0%,rgba(6,22,50,0.08)_100%)]"></div>

      <div class="grid gap-7 lg:grid-cols-[auto_1fr_auto] lg:items-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-[#d6ad3b] bg-white/[0.04] text-[#d6ad3b] shadow-lg shadow-black/10">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-8 w-8 fill-none stroke-current stroke-[1.8]">
            <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm8 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.5 20a4.5 4.5 0 0 1 9 0m-1-3.5A4.5 4.5 0 0 1 20.5 20" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <div>
          <h2 id="join-movement-heading" class="text-2xl font-bold tracking-normal sm:text-3xl">
            {t.title}
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-blue-50/90 sm:text-base">{t.text}</p>
        </div>

        <a
          href={localizePath(lang, t.button.href)}
          class="inline-flex min-h-12 w-fit items-center justify-center gap-4 rounded-md bg-[#d6ad3b] px-7 text-sm font-bold uppercase text-[#061632] shadow-lg shadow-[#02112d]/25 transition duration-300 hover:-translate-y-0.5 hover:bg-[#f0c84d] focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#082b63]"
        >
          {t.button.label}
          <span aria-hidden="true" class="text-xl leading-none">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
